import random


class JeuPFC:
    """
    Pierre Feuille Ciseaux, 2 rounds.
    Actions : 0 = Pierre, 1 = Feuille, 2 = Ciseaux
    L'adversaire joue au hasard au round 0.
    Au round 1, il rejoue le coup que TU as joue au round 0.
    Recompense : +1 si tu gagnes le round, -1 si tu perds, 0 si egalite.
    """

    def __init__(self):
        self.round = 0            # 0 = premier round, 1 = deuxieme round
        self.mon_coup_round0 = None   # ce que l'agent a joue au round 0
        self.fini = False

    def reset(self):
        self.round = 0
        self.mon_coup_round0 = None
        self.fini = False

    def nom(self, coup):
        if coup == 0:
            return "Pierre"
        if coup == 1:
            return "Feuille"
        return "Ciseaux"

    def qui_gagne(self, moi, lui):
        """Renvoie +1 si je gagne, -1 si je perds, 0 si egalite."""
        if moi == lui:
            return 0
        if moi == 0 and lui == 2:   # Pierre bat Ciseaux
            return 1
        if moi == 1 and lui == 0:   # Feuille bat Pierre
            return 1
        if moi == 2 and lui == 1:   # Ciseaux bat Feuille
            return 1
        return -1                   # sinon je perds

    def step(self, action):
        # --- coup de l'adversaire ---
        if self.round == 0:
            coup_adverse = random.randint(0, 2)      # au hasard
        else:
            coup_adverse = self.mon_coup_round0      # il copie mon coup du round 0

        # --- resultat du round ---
        recompense = self.qui_gagne(action, coup_adverse)

        # --- affichage ---
        print("Round", self.round)
        print("  Toi        :", self.nom(action))
        print("  Adversaire :", self.nom(coup_adverse))
        if recompense == 1:
            print("  => GAGNE (+1)")
        elif recompense == -1:
            print("  => PERDU (-1)")
        else:
            print("  => EGALITE (0)")
        print()

        # --- on passe au round suivant ---
        if self.round == 0:
            self.mon_coup_round0 = action
            self.round = 1
        else:
            self.fini = True

        return recompense


